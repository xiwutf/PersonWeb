# AI 服务配置文件示例
# 复制此文件为 .env 并填写实际配置值

# ==================== 服务基础信息 ====================
SERVICE_NAME=ai-service
VERSION=0.1.0

# ==================== 内部鉴权 Token ====================
# 用于 .NET 后端调用 Python Agent 时的身份验证
# 生产环境请务必修改为强密码
AI_INTERNAL_TOKEN=default-internal-token-change-in-production

# ==================== 大模型配置 ====================
# 模型提供商选择: openai, deepseek, qwen
LLM_PROVIDER=deepseek

# OpenAI API 配置（可选，如果使用 OpenAI）
OPENAI_API_KEY=your-openai-api-key-here
DEFAULT_MODEL_NAME=gpt-3.5-turbo

# DeepSeek API 配置（推荐使用）
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL_NAME=deepseek-chat

# 通义千问 API 配置（可选，作为 OpenAI 的替代方案）
QWEN_API_KEY=your-qwen-api-key-here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ==================== Embedding 模型配置 ====================
# 用于文档向量化
EMBEDDING_MODEL_NAME=text-embedding-ada-002
EMBEDDING_DIMENSION=1536

# ==================== 向量数据库配置 ====================
# 向量数据库类型: chroma, milvus, qdrant, faiss
VECTOR_DB_TYPE=chroma
# Chroma 配置
CHROMA_PERSIST_DIRECTORY=./chroma_db
# Milvus 配置
MILVUS_HOST=localhost
MILVUS_PORT=19530
# Qdrant 配置
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ==================== 文档处理配置 ====================
# 文本分段配置
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
# 文档解析超时时间（秒）
DOCUMENT_PARSE_TIMEOUT=300

# ==================== CORS 配置 ====================
# 允许的跨域来源，多个用逗号分隔，* 表示允许所有
ALLOWED_ORIGINS=*

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
LOG_FILE=logs/ai-service.log

# ==================== 数据库配置 ====================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=personal_site
DB_USER=root
DB_PASSWORD=your_password

# ==================== 文件存储配置 ====================
# 文档上传临时目录（.NET 后端会使用此路径）
# 注意：此配置主要用于 Python Agent 读取文件，实际文件存储由 .NET 后端管理
TEMP_FILE_DIR=./temp_files