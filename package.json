{
  "name": "personal-site",
  "version": "1.0.0",
  "description": "溪午听风 - 一个现代化、响应式的个人开发者网站，基于 Nuxt 3 构建",
  "author": "Xie Feng <your-email@example.com>",
  "license": "MIT",
  "homepage": "https://github.com/yourusername/personal-site",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/personal-site.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/personal-site/issues"
  },
  "keywords": [
    "personal-site",
    "nuxt3",
    "vue3",
    "portfolio",
    "developer",
    "blog"
  ],
  "scripts": {
    "dev": "cross-env SASS_SILENCE_DEPRECATIONS=legacy-js-api nuxt dev",
    "dev:mobile": "cross-env SASS_SILENCE_DEPRECATIONS=legacy-js-api nuxt dev --host 0.0.0.0",
    "dev:prod": "cross-env SASS_SILENCE_DEPRECATIONS=legacy-js-api NODE_ENV=production nuxt dev",
    "build": "cross-env SASS_SILENCE_DEPRECATIONS=legacy-js-api NODE_ENV=production nuxt build",
    "generate": "cross-env SASS_SILENCE_DEPRECATIONS=legacy-js-api NODE_ENV=production nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "node scripts/fix-vue-toast-sourcemap.js",
    "lint:colors": "node scripts/lint-colors.js",
    "build:css": "node scripts/build-css.js",
    "optimize:images": "node scripts/optimize-images.js",
    "optimize:all": "node scripts/optimize-all.js",
    "clean:modules": "node scripts/clean-node-modules.js",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "style:lint": "stylelint \"**/*.{vue,css,scss}\" --max-warnings 0",
    "style:lint:fix": "stylelint \"**/*.{vue,css,scss}\" --fix",
    "style:tokens:check": "node node/scripts/check-design-tokens.js scan",
    "style:tokens:verify": "node node/scripts/verify-design-tokens.js",
    "check:budget": "node scripts/check-budget.js",
    "perf:analyze": "node scripts/performance-recommendations.js",
    "perf:lighthouse": "lhci autorun --collect.url=http://localhost:3000/ --collect.numRuns=1",
    "lighthouse:report": "lhci collect --url=http://localhost:3000/ --numberOfRuns=3",
    "build:analyze": "cross-env ANALYZE=true npm run build",
    "bundle:analyze": "nuxt build --analyze",
    "perf:regression:test": "node scripts/test-performance-regression.js test",
    "perf:baseline:update": "node scripts/test-performance-regression.js update-baseline"
  },
  "devDependencies": {
    "@lhci/cli": "^0.13.0",
    "@nuxt/content": "^3.12.0",
    "@nuxtjs/tailwindcss": "^6.7.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.10.1",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "@vue/test-utils": "^2.4.6",
    "benchmark": "^2.1.4",
    "cross-env": "^10.1.0",
    "cssmin": "^0.4.3",
    "glob": "^13.0.6",
    "happy-dom": "^20.8.4",
    "jsdom": "^24.1.0",
    "markdown-it": "^14.1.0",
    "nuxt": "^3.10.0",
    "rollup-plugin-visualizer": "^5.12.0",
    "sharp": "^0.34.5",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "web-vitals": "^4.2.4",
    "@bytemd/plugin-gfm": "^1.22.0",
    "@bytemd/plugin-highlight": "^1.22.0",
    "@bytemd/plugin-math": "^1.22.0",
    "@bytemd/plugin-medium-zoom": "^1.22.0",
    "@bytemd/vue-next": "^1.22.0",
    "@motionone/dom": "^10.18.0",
    "@motionone/vue": "^10.16.4",
    "@types/three": "^0.181.0",
    "@types/uuid": "^10.0.0",
    "@vicons/ionicons5": "^0.12.0",
    "bytemd": "^1.22.0",
    "chart.js": "^3.9.1",
    "diff-match-patch": "^1.0.5",
    "echarts": "^6.0.0",
    "mysql2": "^3.15.3",
    "naive-ui": "^2.43.2",
    "three": "^0.181.2",
    "uuid": "^13.0.0",
    "vfonts": "^0.0.3",
    "vue-chartjs": "^4.1.1",
    "vue-echarts": "^8.0.1",
    "vue-toast-notification": "^3.1.3"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.6.2"
  }
}
